# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nosenv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
vulture_whitelist.py

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this should be ignored:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a windows machine, Pipfile.lock might not be portable.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock is generally recommended, but can be ignored.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock is generally recommended, but can be ignored.
#pdm.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and github.com/pdm-project/pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Project specific data files (Micro-Expression Detection)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Checkpoints (ignore intermediate models to save repo space)
checkpoints/fold*
checkpoints/fold*.pt
checkpoints/*_epoch*.pt

# Keep the best checkpoints but ignore other heavy checkpoint files
# checkpoints/best_fold0_baseline.pt
# checkpoints/best_fold0_flow_cnn.pt
# checkpoints/best_fold0_flow_only.pt
# checkpoints/best_fold0_full.pt
# checkpoints/best_fold1_full.pt

# Ignore standard runtime logs
logs/*.log
logs/*.txt
!logs/.gitkeep
